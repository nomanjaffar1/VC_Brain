{
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/**/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/api/v1/$1.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
